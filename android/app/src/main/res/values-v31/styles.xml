<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- API 31+ (Android 12): SplashScreen API — fondo oscuro BioTech -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:statusBarColor">#FF080F08</item>
        <item name="android:navigationBarColor">#FF080F08</item>
        <!-- Color de fondo del splash nativo en Android 12+ -->
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowSplashScreenBackground">#0A0A0A</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
